# Linen Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it contains secrets

# Gemini API Key (stored securely in Firebase Cloud Functions, not used in frontend)
# This is for documentation purposes only
VITE_FIREBASE_PROJECT_ID=linen-a1142

# Firebase Functions Region
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Note: The actual Gemini API key is stored in Firebase Secrets Manager
# and accessed only by the Cloud Functions backend, never exposed to the frontend.
